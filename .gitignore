# ============================================================
# R / RStudio
# ============================================================

.Rhistory
.RData
.Ruserdata
.Rproj.user/
*.Rproj

# ============================================================
# Local environment / package management
# ============================================================

.Renviron
.Rprofile

# Keep renv files only if you decide to use renv.
# If you are not using renv, these patterns do nothing.
renv/library/
renv/staging/

# ============================================================
# Raw and processed data
# ============================================================

data_raw/*
data_processed/*

# Keep folder documentation
!data_raw/README.md
!data_processed/README.md

# ============================================================
# Generated outputs
# ============================================================

output/*
!output/README.md

# Old local output folders from previous pipeline versions
output_*/
archive_old_outputs/

# ============================================================
# Data and analysis products
# ============================================================

*.RData
*.rda
*.rds
*.csv
*.tsv
*.xlsx
*.xls
*.sav
*.dta
*.parquet
*.feather
*.fst

